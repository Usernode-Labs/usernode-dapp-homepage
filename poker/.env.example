# Usernode Hold'em — local/standalone env. The platform injects DATABASE_URL,
# JWT_SECRET, PORT, USERNODE_ENV and the dapp.json secrets at deploy time.

#DATABASE_URL=postgres://user:pass@localhost:5432/holdem
#JWT_SECRET=dev-secret
#USERNODE_ENV=staging
#PORT=3000

# Custodial table treasury (see dapp.json). Public address + private signing key.
#TREASURY_ADDRESS=ut1...
#TREASURY_SIGNING_KEY=...

#SMALL_BLIND=25
#BIG_BLIND=50
#MIN_BUYIN=1000
#MAX_BUYIN=10000
#ACTION_TIMER_SECONDS=30

# Node RPC for treasury submits (platform-managed in-network).
#NODE_RPC_URL=http://usernode-node:3001
