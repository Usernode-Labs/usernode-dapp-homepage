# Dapp Homepage — Environment Configuration
#
# Copy this file to .env and adjust values as needed.
# .env is gitignored and will not be committed.

# Server port (default: 8000)
#PORT=8000

# Override the path to the dapps JSON config file.
# When --local-dev is passed, the server automatically uses dapps.local.json
# (if it exists) without needing this variable. Use DAPPS_JSON_PATH only if
# you want to point at a completely custom file.
#DAPPS_JSON_PATH=./my-dapps.json

# ── Submit-a-dapp flow ────────────────────────────────────────────────────────
# These are declared as secrets in dapp.json (the platform injects them at
# deploy time). For standalone/local runs, set them here. On a confirmed
# payment the dapp is auto-published to dapps.json — there is no review step.

# Usernode address (ut1…) that submission fees are burned to — the Community
# Fund Reserve (may be a burn address). Leave unset to disable the submit flow.
#COMMUNITY_FUND_RESERVE_ADDRESS=ut1...

# One-time fee in tokens to submit a dapp (default 1000). A confirmed transfer
# must carry amount >= this value.
#SUBMISSION_FEE=1000

# Hours an unpaid submission stays in awaiting_payment before it is swept to
# expired (default 24). A genuine late payment is still credited.
#SUBMISSION_TTL_HOURS=24

# Override the path to the submissions store (default ./submissions.json).
#SUBMISSIONS_JSON_PATH=./submissions.json

# ── Trivia Quiz ───────────────────────────────────────────────────────────────
# A public /trivia page: timed multi-question quiz, server-graded, with a global
# best-per-player leaderboard. These are declared as (public, non-private)
# secrets in dapp.json; the platform injects them at deploy time. For
# standalone/local runs, set them here.

# Usernode address (ut1…) shown as the source of future reward payouts. This
# phase is display-only — no tokens move yet. Leave unset to hide the address.
#QUIZ_PRIZE_POOL_ADDRESS=ut1...

# How many questions per quiz session (default 10; capped to the bank size).
#QUIZ_QUESTIONS_PER_SESSION=10

# Per-session countdown in seconds; the quiz auto-submits at zero (default 120).
#QUIZ_TIME_LIMIT_SECONDS=120

# Minimum correct answers (with a valid ut1 wallet) to be reward-eligible
# (default 8).
#QUIZ_ELIGIBILITY_MIN_CORRECT=8

# Override the path to the quiz score store (default ./quiz-scores.json).
#QUIZ_SCORES_JSON_PATH=./quiz-scores.json
